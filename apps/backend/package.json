{
    "name": "backend",
    "version": "1.0.50",
    "scripts": {
        "test": "echo \"Error: no test specified\" && exit 1",
        "dev": "bun run --watch src/app.ts",
        "build": "bun build --compile --minify-whitespace --minify-syntax --target bun --outfile server src/app.ts",
        "db:push": "bunx drizzle-kit push",
        "db:gen": "bunx drizzle-kit generate",
        "db:migrate": "bunx drizzle-kit migrate",
        "db:reset": "bun run src/lib/db/reset.ts",
        "db:seed": "bun run src/lib/db/seed/seed-dev.ts"
    },
    "dependencies": {
        "@elysiajs/cors": "^1.4.1",
        "@elysiajs/openapi": "^1.4.14",
        "drizzle-orm": "^0.45.1",
        "elysia": "latest",
        "pg": "^8.18.0",
        "winston": "^3.19.0",
        "zod": "^4.3.6",
        "@my-wallet/type-check": "workspace:*"
    },
    "devDependencies": {
        "@biomejs/biome": "2.3.15",
        "@types/pg": "^8.16.0",
        "bun-types": "latest",
        "drizzle-kit": "^0.31.9",
        "turbo": "^2.8.10"
    },
    "module": "src/index.js"
}